#include <dt-bindings/zmk/matrix_transform.h>
#include <zephyr/dt-bindings/pinctrl/rpi-pico-rp2040-pinctrl.h>
#include "dilemma-layouts.dtsi"

&pio0 {
    status = "okay";

    pio0_uart0: serial {
        status = "okay";
        compatible = "raspberrypi,pico-uart-pio";
        pinctrl-names = "default";
        current-speed = <115200>;
    };
};

/ {
    chosen {
        zmk,physical-layout = &dilemma_3x5_3_layout;
        zmk,split-uart = &pio0_uart0;
    };

    dilemma_3x5_3_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <5>;
        map = <
            RC(0, 0) RC(0, 1) RC(0, 2) RC(0, 3) RC(0, 4)    RC(0, 5) RC(0,11) RC(0,10) RC(0, 9) RC(0, 8)
            RC(1, 0) RC(1, 1) RC(1, 2) RC(1, 3) RC(1, 4)    RC(1, 5) RC(1,11) RC(1,10) RC(1, 9) RC(1, 8)
            RC(2, 0) RC(2, 1) RC(2, 2) RC(2, 3) RC(2, 4)    RC(2, 5) RC(2,11) RC(2,10) RC(2, 9) RC(2, 8)
                              RC(3, 0) RC(3, 1) RC(3, 2)    RC(3, 3) RC(3, 4) RC(3, 5)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "row2col";
		wakeup-source;
    };
};
